{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "pocSlug": { "value": "mypoc" },
    "location": { "value": "eastus" },
    "keyVaultName": { "value": "kv-mypoc" },
    "appConfigConnectionString": {
      "value": "Endpoint=https://appconfig-mypoc-poc.azconfig.io;Id=<read-only-key-id>;Secret=<read-only-key-secret>"
    },
    "frontendImage": {
      "value": "DOCKER|creyaifinmain.azurecr.io/aifinance-frontend:latest"
    },
    "backendImage": {
      "value": "DOCKER|creyaifinmain.azurecr.io/aifinance-backend:latest"
    },
    "acrManagedIdentityClientId": {
      "value": "<client-id-of-acr-managed-identity>"
    }
  }
}
